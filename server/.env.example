# Puerto HTTP (detrás de nginx/Caddy en results.dotrino.com).
PORT=8092

# Competición y ventana de fechas (rango ESPN/FIFA, todo el torneo en una request).
RESULTS_COMPETITION=fifa.world.2026
RESULTS_FROM=20260611
RESULTS_TO=20260719

# Cadena de proveedores en orden de preferencia (primero = mejor; resto fallback).
RESULTS_PROVIDERS=espn,fifa

# Cada cuánto re-consulta a los proveedores (ms). 30s alcanza de sobra.
RESULTS_POLL_MS=30000

# Allowlist de admins que pueden cargar resultados manuales (firmados por su
# vault). Thumbprints (pubkeyId hex) o JWK strings completos, separados por coma.
# Vacío = nadie puede cargar overrides (solo proveedores).
RESULTS_ADMIN_PUBKEYS=

# Clave de SERVICIO con la que el relay firma el feed. Si se deja vacío, se
# genera y persiste en data/relay-key.json (0600). Su pubkey (GET /pubkey) se
# PINEA en el cliente. Para fijarla por env, pegar el JWK privado completo:
# RESULTS_PRIVATE_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
RESULTS_PRIVATE_JWK=

# Archivos de estado (default: data/ junto al server).
# RESULTS_KEY_FILE=./data/relay-key.json
# RESULTS_STORE_FILE=./data/overrides.json
